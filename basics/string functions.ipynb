   "source": [
    "# This function returns the length of the strings.\n",
    "name=\"jerry\"\n",
    "print(len(name))\n",
    "# Capitalizes the string\n",
    "print(name.capitalize())\n",
    "# Checks if the string ends with rry or not\n",
    "print(name.endswith(\"rry\"))\n",
    "# Checks if the string starts with jer or not\n",
    "print(name.startswith(\"jr\"))\n"
   ]
